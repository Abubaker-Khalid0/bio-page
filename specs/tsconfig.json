{
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "strict": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "noEmit": true,
        "typeRoots": [
            "../lyore-bio/node_modules/@types"
        ],
        "baseUrl": ".",
        "paths": {
            "*": [
                "../lyore-bio/node_modules/*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}